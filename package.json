{
  "name": "cmdforge",
  "version": "0.1.0",
  "description": "Generic package manager for AI assistant commands",
  "type": "module",
  "bin": {
    "ocmd": "bin/ocmd.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "bin",
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "fs-extra": "^11.2.0",
    "picocolors": "^1.0.0",
    "ora": "^8.0.0",
    "ofetch": "^1.3.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.0",
    "prettier": "^3.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "homepage": "https://github.com/EhsaasChaudhary/open-cmd#readme",
  "bugs": {
    "url": "https://github.com/EhsaasChaudhary/open-cmd/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EhsaasChaudhary/open-cmd.git"
  },
  "keywords": [
    "cli",
    "ai",
    "commands",
    "opencode"
  ]
}
